# Copy to .env for local development only — never commit real values.
NODE_ENV=development
CONTACT_EMAIL_FROM=
CONTACT_EMAIL_TO=
# Local only: set true to log email payload without SES (never in deployed stages)
EMAIL_DRY_RUN=false
CORS_ALLOWED_ORIGINS=https://dev.novusintelligence.com,http://localhost:5173
RATE_LIMIT_PER_IP=10
CAPTCHA_ENABLED=false
CAPTCHA_PROVIDER=turnstile
CAPTCHA_SECRET=
CRM_WEBHOOK_URL=
LOG_LEVEL=info
